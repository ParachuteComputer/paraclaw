{
  "name": "@openparachute/agent",
  "version": "0.1.4-rc.1",
  "description": "Parachute Agent — per-session containerized AI agent companion.",
  "license": "AGPL-3.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "parachute": "bun scripts/parachute.ts",
    "build:spa": "cd web/ui && pnpm install --frozen-lockfile --ignore-workspace && pnpm build",
    "postinstall": "if [ -d web/ui ]; then pnpm run build:spa; fi",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@chat-adapter/discord": "4.26.0",
    "@chat-adapter/telegram": "4.26.0",
    "@clack/core": "^1.2.0",
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openparachute/scope-guard": "^0.2.1",
    "chat": "^4.24.0",
    "cron-parser": "5.5.0",
    "jose": "^6.2.2",
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "better-sqlite3": "11.10.0",
    "bun-types": "^1.3.13",
    "eslint": "^9.35.0",
    "eslint-plugin-no-catch-all": "^1.1.0",
    "globals": "^15.12.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "bun": ">=1.3"
  }
}
